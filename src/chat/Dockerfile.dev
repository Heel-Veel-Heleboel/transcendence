FROM node:24-alpine

# create non-privileged user and group
RUN addgroup -S appgroup && adduser -S app -G appgroup

# create and own workdir
WORKDIR /app
RUN chown app:appgroup /app

# add dependenies
RUN apk add --no-cache python3 make g++
COPY prisma.config.ts ./
COPY prisma ./prisma/

# copy package files as root (safe) then set ownership so app can write
COPY package.json package-lock.json ./
RUN chown app:appgroup package.json package-lock.json

# install dependencies as app (now owns files)
RUN npm install

# add other configuration
COPY tsconfig.json ./
COPY src ./src/
COPY .env* ./

# build app
RUN npm run db:generate
RUN npm run build

# copy rest of files as root but set ownership in one step
COPY --chown=app:appgroup . .

EXPOSE 3006

# add runuser for entrypoint script
RUN apk add util-linux

# setup entrypoint script for non-root volume access
COPY entrypoint-dev.sh ./entrypoint-dev.sh
ENTRYPOINT ["/bin/sh", "entrypoint-dev.sh"]

RUN npm run db:push

CMD ["node", "--env-file-if-exists=.env", "dist/src/index.js"]

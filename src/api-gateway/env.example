# API Gateway Configuration

# Config file paths (relative to working directory)
SERVICES_FILE=path/to/services_config
RATE_LIMITS_FILE=path/to/rate_limits_config

# Server
HOST=0.0.0.0
NODE_ENV=development

# CORS Configuration
ALLOWED_ORIGINS=https://localhost:5173,https://localhost:3000
CORS_CREDENTIALS=true
CORS_ALLOWED_METHODS=all methods(e.g. GET, POST)
CORS_ALLOWED_HEADERS=Content-Type,Authorization,
CORS_EXPOSED_HEADERS=

# Security
BODY_LIMIT_BYTES=1048576

# HSTS (HTTP Strict Transport Security)
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# Content Security Policy
CSP_DEFAULT_SRC='self'
CSP_STYLE_SRC='self'
CSP_SCRIPT_SRC='self'
CSP_IMG_SRC='self',data:,https:

# Auth Service Configuration

# Password policy
PASSWORD_MAX_LENGTH=72
PASSWORD_MIN_LENGTH=8
BCRYPT_SALT_ROUNDS=12

# JWT settings
# Paths to RSA key files — generate with: openssl genrsa -out keys/jwt_private.pem 2048
JWT_PRIVATE_KEY_PATH=./path/to/keys
JWT_PUBLIC_KEY_PATH=./path/to/keys
EXPIRATION_TIME_ACCESS_TOKEN=15m
EXPIRATION_TIME_REFRESH_TOKEN=7d

# Database
DATABASE_URL=file:./dev.db

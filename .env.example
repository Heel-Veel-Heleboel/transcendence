# Docker project namespace (defaults to the current folder name if not set)
COMPOSE_PROJECT_NAME=transcendence

# Observability stack (Elasticsearch, Kibana, Logstash)
# Only needed when running docker-compose.observability.yml

ELASTIC_USER=elastic
ELASTIC_PASSWORD=changeme

KIBANA_USER=kibana_system
KIBANA_PASSWORD=changeme

STACK_VERSION=8.11.0
CLUSTER_NAME=docker-cluster
LICENSE=basic

ES_PORT=9200
KIBANA_PORT=5601

ES_MEM_LIMIT=1073741824
KB_MEM_LIMIT=1073741824
LS_MEM_LIMIT=1073741824

ENCRYPTION_KEY=changeme
